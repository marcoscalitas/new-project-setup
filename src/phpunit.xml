<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="vendor/phpunit/phpunit/phpunit.xsd"
         bootstrap="vendor/autoload.php"
         colors="true"
>
    <testsuites>
        <testsuite name="Unit">
            <directory>tests/Unit</directory>
        </testsuite>
        <testsuite name="Feature">
            <directory>tests/Feature</directory>
        </testsuite>
        <testsuite name="Auth-Web">
            <directory>modules/Auth/Tests/Web</directory>
        </testsuite>
        <testsuite name="Auth-Api">
            <directory>modules/Auth/Tests/Api</directory>
        </testsuite>
        <testsuite name="User-Api">
            <directory>modules/User/Tests/Api</directory>
        </testsuite>
        <testsuite name="User-Web">
            <directory>modules/User/Tests/Web</directory>
        </testsuite>
        <testsuite name="Permission-Api">
            <directory>modules/Permission/Tests/Api</directory>
        </testsuite>
        <testsuite name="Permission-Web">
            <directory>modules/Permission/Tests/Web</directory>
        </testsuite>
        <testsuite name="Notification-Api">
            <directory>modules/Notification/Tests/Api</directory>
        </testsuite>
        <testsuite name="Notification-Web">
            <directory>modules/Notification/Tests/Web</directory>
        </testsuite>
        <testsuite name="Horizon">
            <file>tests/Feature/HorizonTest.php</file>
        </testsuite>
        <testsuite name="Telescope">
            <file>tests/Feature/TelescopeTest.php</file>
        </testsuite>
    </testsuites>
    <source>
        <include>
            <directory>app</directory>
            <directory>modules</directory>
        </include>
    </source>
    <php>
        <env name="APP_ENV" value="testing"/>
        <env name="APP_MAINTENANCE_DRIVER" value="file"/>
        <env name="BCRYPT_ROUNDS" value="4"/>
        <env name="BROADCAST_CONNECTION" value="null"/>
        <env name="CACHE_STORE" value="array"/>
        <env name="DB_CONNECTION" value="sqlite"/>
        <env name="DB_DATABASE" value=":memory:"/>
        <env name="MAIL_MAILER" value="array"/>
        <env name="QUEUE_CONNECTION" value="sync"/>
        <env name="SESSION_DRIVER" value="array"/>
        <env name="PULSE_ENABLED" value="false"/>
        <env name="TELESCOPE_ENABLED" value="false"/>
        <env name="NIGHTWATCH_ENABLED" value="false"/>
        <env name="MEDIA_DISK" value="minio"/>
    </php>
</phpunit>
