# ============================================
# Docker Build Context — Exclusions
# ============================================
# The PHP image never COPYs source from the host
# (src/ is mounted as a volume at runtime).
# Only docker/php/Dockerfile needs to be in context.
# ============================================

# Git
.git
.gitignore
.gitattributes

# Source code (mounted as volume, not baked in)
src/

# Environment files (never expose to build daemon)
.env
.env.*
!.env.example

# Services unrelated to the PHP build
docker/nginx
docker/postgres
docker/redis

# Documentation
*.md
LICENSE*

# Editor / OS artefacts
.vscode
.idea
*.swp
*.swo
.DS_Store
Thumbs.db
