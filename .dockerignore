# ============================================
# Docker Build Context — Exclusions
# ============================================
# The node-builder stage needs src/ to compile
# Vite assets. Exclude only heavy/sensitive dirs.
# ============================================

# Git
.git
.gitignore
.gitattributes

# Heavy directories (not needed in build)
src/vendor/
src/node_modules/
src/storage/logs/
src/.phpunit.cache/

# Environment files (never expose to build daemon)
.env
.env.*
!.env.example

# Services unrelated to the PHP build
docker/nginx
docker/postgres
docker/redis

# Documentation
*.md
LICENSE*

# Backups
backups/

# Editor / OS artefacts
.vscode
.idea
*.swp
*.swo
.DS_Store
Thumbs.db
