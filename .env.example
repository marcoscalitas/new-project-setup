# ============================================
# Docker Configuration
# ============================================
# Copy to .env before running setup.sh.
# POSTGRES_PASSWORD and REDIS_PASSWORD are
# auto-generated by setup.sh if left empty.
# ============================================

# --- Project ---
PROJECT_NAME=myproject
APP_ENV=local
APP_PORT=8080

# --- PostgreSQL ---
POSTGRES_DB=myproject_db
POSTGRES_USER=myproject_user
POSTGRES_PASSWORD=

# --- Redis ---
REDIS_PORT=6379
REDIS_PASSWORD=

# --- Node / Vite (dev only) ---
VITE_PORT=5173

# --- Mailpit (dev only) ---
MAILPIT_PORT=8025
MAILPIT_SMTP_PORT=1025
