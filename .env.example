# ============================================
# Docker Configuration
# ============================================
# Copy to .env before running setup.sh.
# POSTGRES_PASSWORD and REDIS_PASSWORD are
# auto-generated by setup.sh if left empty.
# ============================================

# --- Project ---
PROJECT_NAME=yadah-prod
APP_ENV=local
APP_PORT=8080

# --- PostgreSQL ---
POSTGRES_DB=yadah_prod_db
POSTGRES_USER=yadah_prod_user
POSTGRES_PASSWORD=

# --- Redis ---
REDIS_PASSWORD=

# --- Node / Vite (dev only) ---
VITE_PORT=5173

# --- Mailpit (dev only) ---
MAILPIT_PORT=8025
